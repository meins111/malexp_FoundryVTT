      "type": "trait",
      "_id": "PSYTrait1",
      "img": "modules/impmal-core/assets/icons/blank.webp",
      "system": {
        "notes": {
          "player": "<p>At the start of the Psychomancer's turn, it regains 4 Wounds. It is immune to the Bleeding, Fatigued, Frightened, and Poisoned Conditions. Additionally, it has no soul and cannot be detected by abilities such as Soulsight.</p>",
          "gm": ""
        },
        "attack": {
